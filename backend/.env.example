WH_BIND=0.0.0.0:8080
WH_S3_BUCKET=wormhole-blobs
WH_REDIS_URL=redis://127.0.0.1:6379/
WH_TTL_SECS=86400
WH_MAX_UPLOAD_BYTES=104857600
WH_LOOKUP_LIMIT=20
WH_LOOKUP_WINDOW_SECS=60

# AWS creds via standard chain: env, ~/.aws, or IAM role.
# For local MinIO dev:
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL=http://127.0.0.1:9000
